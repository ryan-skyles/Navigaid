# Server
PORT=3001

# PostgreSQL (database: aiddb)
# Use either DATABASE_URL or the individual variables below.
# DATABASE_URL=postgresql://user:password@localhost:5432/aiddb

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=aiddb

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key
